{
  "name": "caseroom",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n runtime,web,electron \"npm run dev:runtime\" \"npm run dev:web\" \"npm run dev:electron\"",
    "dev:web": "npm run dev --workspace @caseroom/desktop",
    "dev:runtime": "npm run dev --workspace @caseroom/qvac-runtime",
    "dev:electron": "npm run dev:electron --workspace @caseroom/desktop",
    "build": "npm run build --workspace @caseroom/desktop",
    "lint": "npm run lint --workspace @caseroom/desktop",
    "typecheck": "npm run typecheck --workspace @caseroom/desktop",
    "test": "vitest run packages/simulation-core/src/index.test.ts packages/qvac-runtime/src/index.test.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "qvac:shutdown": "node -e \"const base=process.env.CASE_ROOM_QVAC_URL||'http://127.0.0.1:4545'; fetch(base + '/shutdown',{method:'POST'}).then(r=>r.text()).then(t=>console.log(t)).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "evidence:bundle": "node scripts/collect-submission-artifacts.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
