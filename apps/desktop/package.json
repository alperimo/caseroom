{
  "name": "@caseroom/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env CASE_ROOM_DEV_SERVER_URL=http://127.0.0.1:5173 node ./electron/launch.cjs",
    "start": "node ./electron/launch.cjs",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@caseroom/case-packs-medical-osce": "file:../../packages/case-packs/medical-osce",
    "@caseroom/qvac-runtime": "file:../../packages/qvac-runtime",
    "@caseroom/simulation-core": "file:../../packages/simulation-core",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^10.0.0",
    "electron": "^31.7.7",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.3"
  }
}
